{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignore": ["src/core/SceneExtensions.ts"],
  "ignoreDependencies": ["@types/katex", "typedoc"],
  "ignoreUnresolved": ["typia/lib/transform"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "rules": {
    "optionalPeerDependencies": "off",
    "duplicates": "off"
  }
}
